{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_TMDB_API_KEY": "@tmdb_api_key"
  },
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/search/(.*)",
      "destination": "/search"
    }
  ]
}
